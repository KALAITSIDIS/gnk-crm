# --- Supabase (required from Sprint 0) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only, never exposed to client

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en
TZ=Asia/Nicosia

# --- Error tracking (T5.7) — leave blank to disable; Sentry is a no-op without a DSN ---
SENTRY_DSN=                           # server/edge capture (instrumentation.ts)
NEXT_PUBLIC_SENTRY_DSN=               # browser capture (instrumentation-client.ts)

# --- Optional until later sprints/phases ---
RESEND_API_KEY=                       # email (Phase 2+)
